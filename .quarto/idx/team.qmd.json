{"title":"1. Open the Quarto wide container","markdown":{"yaml":{"title":"","format":{"html":{"page-layout":"full","anchor-sections":false,"css":"style.css"}}},"headingText":"1. Open the Quarto wide container","containsRefs":false,"markdown":"\n\n\n<center>[**Our Team**]{style=\"font-size: 24px;\"}</center>\n\n------------------------------------------------------------------------\n\n```{r,echo=FALSE, message=FALSE, warning=T, results='asis'}\ncat('<link rel=\"stylesheet\" href=\"https://cdn.jsdelivr.net/gh/lipis/flag-icons@7.2.3/css/flag-icons.min.css\"/>')\n\nlibrary(readxl)\nlibrary(tidyverse)\n\npi <- read_xlsx(\"data/team.xlsx\") %>%\n  filter(position == \"pi\")\n\ncat('<center>[**Principal Investigator**]{style=\"font-size: 24px;\"}</center>')\ncat(str_glue('\n<div style=\"margin-bottom: 20px; margin-top: 20px;\">\n  <table style=\"width: 100%; border-collapse: collapse; margin-bottom: 30px; background: transparent;\">\n    <tr>\n      <td style=\"width: 20%; vertical-align: top; padding-right: 20px;\">\n        <img src=\"{pi$photo}\" alt=\"Profile Photo\" style=\"width: 100%; border-radius: 5%;\">\n      </td>\n      <td style=\"width: 80%; vertical-align: top;\">\n        <h3 style=\"margin-top: 0; margin-bottom: 5px;\">{pi$name} <span class=\"fi fi-br\" style=\"transform: scale(0.7); display: inline-block;\"></span><span class=\"fi fi-kr\" style=\"transform: scale(0.7); display: inline-block;\"></span></h3>\n        {if (!is.na(pi$contact)) paste0(\\'<a href=\"mailto:\\', pi$contact, \\'\" style=\"color:#444;margin-right:10px;\"><i class=\"bi bi-envelope-fill\"></i></a>\\') else \"\"}\n        {if (!is.na(pi$linkedin)) paste0(\\'<a href=\"https://\\', pi$linkedin, \\'\" style=\"color:#0077b5;margin-right:10px;\"><i class=\"bi bi-linkedin\"></i></a>\\') else \"\"}\n        {if (!is.na(pi$bluesky)) paste0(\\'<a href=\"https://\\', pi$bluesky, \\'\" style=\"color:#0085ff;margin-right:10px;\"><i class=\"bi bi-bluesky\"></i></a>\\') else \"\"}\n        <p style=\"color:#666; font-style:italic; margin-bottom:15px;\">{pi$subheading}</p>\n        <p style=\"text-align:justify; line-height:1.5; margin-top:10px;font-size: 16px;\">{pi$description}</p>\n      </td>\n    </tr>\n  </table>\n</div>\n'))\n\n```\n\n------------------------------------------------------------------------\n\n```{r,echo=FALSE, message=FALSE, warning=T, results='asis'}\nlibrary(readxl)\nlibrary(tidyverse)\n\ncurrent <- read_xlsx(\"data/team.xlsx\") %>%\n  filter(status == \"current\") %>%\n  filter(!position == \"pi\")\n\nif (nrow(current) > 0) {\n\ncat('<center>[**Current members**]{style=\"font-size: 24px;\"}</center>')\n  \nfor (k in 1:nrow(current)) { \n  \ncurrent.member <- current[k,]\ncat(str_glue('\n<div style=\"margin-bottom: 20px; margin-top: 20px;\">\n  <table style=\"width: 100%; border-collapse: collapse; margin-bottom: 30px; background: transparent;\">\n    <tr>\n      <td style=\"width: 20%; vertical-align: top; padding-right: 20px;\">\n        <img src=\"{current.member$photo}\" alt=\"Profile Photo\" style=\"width: 100%; border-radius: 5%;\">\n      </td>\n      <td style=\"width: 80%; vertical-align: top;\">\n        <h3 style=\"margin-top: 0; margin-bottom: 5px;\">{current.member$name} <span class=\"fi fi-{current.member$nation}\" style=\"transform: scale(0.7); display: inline-block;\"></span></h3>\n        {if (!is.na(current.member$contact)) paste0(\\'<a href=\"mailto:\\', current.member$contact, \\'\" style=\"color:#444;margin-right:10px;\"><i class=\"bi bi-envelope-fill\"></i></a>\\') else \"\"}\n        {if (!is.na(current.member$linkedin)) paste0(\\'<a href=\"https://\\', current.member$linkedin, \\'\" style=\"color:#0077b5;margin-right:10px;\"><i class=\"bi bi-linkedin\"></i></a>\\') else \"\"}\n        {if (!is.na(current.member$bluesky)) paste0(\\'<a href=\"https://\\', current.member$bluesky, \\'\" style=\"color:#0085ff;margin-right:10px;\"><i class=\"bi bi-bluesky\"></i></a>\\') else \"\"}\n        <p style=\"color:#666; font-style:italic; margin-bottom:15px;\">{current.member$subheading}</p>\n        <p style=\"text-align:justify; line-height:1.5; margin-top:10px;font-size: 18px;\">{current.member$description}</p>\n      </td>\n    </tr>\n  </table>\n</div>\n'))\n\n\n}\n} else {invisible(NULL)}\n```\n\n------------------------------------------------------------------------\n\n```{r, echo=FALSE, message=FALSE, warning=FALSE, results='asis'}\nlibrary(readxl)\nlibrary(tidyverse)\n\nalumni <- read_xlsx(\"data/team.xlsx\") %>%\n  filter(status == \"alumni\") %>%\n  filter(!position == \"pi\") %>%\n  arrange(position)\n\nif (nrow(alumni) > 0) {\n  cat('<center>[**Alumni members**]{style=\"font-size: 24px;\"}</center>')\n  cat('<div style=\"display: grid; grid-template-columns: repeat(4, 1fr); gap: 20px; margin: 20px 0; align-items: start;\">')\n  \n  for (k in 1:nrow(alumni)) {\n    alumni.member <- alumni[k,]\n    \n    icons <- paste0(\n      if (!is.na(alumni.member$contact)) paste0('<a href=\"mailto:', alumni.member$contact, '\" style=\"color:#444;margin-right:10px;\"><i class=\"bi bi-envelope-fill\"></i></a>') else \"\",\n      if (!is.na(alumni.member$linkedin)) paste0('<a href=\"https://', alumni.member$linkedin, '\" style=\"color:#0077b5;margin-right:10px;\"><i class=\"bi bi-linkedin\"></i></a>') else \"\",\n      if (!is.na(alumni.member$bluesky)) paste0('<a href=\"https://', alumni.member$bluesky, '\" style=\"color:#0085ff;margin-right:10px;\"><i class=\"bi bi-bluesky\"></i></a>') else \"\"\n    )\n    \n    cat(str_glue('\n    <div style=\"text-align: center; padding: 10px;\">\n      <img src=\"{alumni.member$photo}\" alt=\"Profile Photo\"\n           style=\"width: 50%; border-radius: 10%; display: block; margin: 0 auto;\">\n      <h3 style=\"margin-top: 8px; margin-bottom: 5px; font-size: 18px;\">\n        {alumni.member$name}\n        <span class=\"fi fi-{alumni.member$nation}\" style=\"transform: scale(0.7); display: inline-block;\"></span>\n      </h3>\n      <div style=\"margin-top: 5px;\">{icons}</div>\n      <div style=\"margin-top: 5px;\">{alumni.member$subheading}</div>\n    </div>\n    '))\n  }\n  \n  cat('</div>')\n  \n} else { invisible(NULL) }\n```\n\n\n","srcMarkdownNoYaml":"\n\n\n<center>[**Our Team**]{style=\"font-size: 24px;\"}</center>\n\n------------------------------------------------------------------------\n\n```{r,echo=FALSE, message=FALSE, warning=T, results='asis'}\ncat('<link rel=\"stylesheet\" href=\"https://cdn.jsdelivr.net/gh/lipis/flag-icons@7.2.3/css/flag-icons.min.css\"/>')\n\nlibrary(readxl)\nlibrary(tidyverse)\n\npi <- read_xlsx(\"data/team.xlsx\") %>%\n  filter(position == \"pi\")\n\ncat('<center>[**Principal Investigator**]{style=\"font-size: 24px;\"}</center>')\n# 1. Open the Quarto wide container\ncat(str_glue('\n<div style=\"margin-bottom: 20px; margin-top: 20px;\">\n  <table style=\"width: 100%; border-collapse: collapse; margin-bottom: 30px; background: transparent;\">\n    <tr>\n      <td style=\"width: 20%; vertical-align: top; padding-right: 20px;\">\n        <img src=\"{pi$photo}\" alt=\"Profile Photo\" style=\"width: 100%; border-radius: 5%;\">\n      </td>\n      <td style=\"width: 80%; vertical-align: top;\">\n        <h3 style=\"margin-top: 0; margin-bottom: 5px;\">{pi$name} <span class=\"fi fi-br\" style=\"transform: scale(0.7); display: inline-block;\"></span><span class=\"fi fi-kr\" style=\"transform: scale(0.7); display: inline-block;\"></span></h3>\n        {if (!is.na(pi$contact)) paste0(\\'<a href=\"mailto:\\', pi$contact, \\'\" style=\"color:#444;margin-right:10px;\"><i class=\"bi bi-envelope-fill\"></i></a>\\') else \"\"}\n        {if (!is.na(pi$linkedin)) paste0(\\'<a href=\"https://\\', pi$linkedin, \\'\" style=\"color:#0077b5;margin-right:10px;\"><i class=\"bi bi-linkedin\"></i></a>\\') else \"\"}\n        {if (!is.na(pi$bluesky)) paste0(\\'<a href=\"https://\\', pi$bluesky, \\'\" style=\"color:#0085ff;margin-right:10px;\"><i class=\"bi bi-bluesky\"></i></a>\\') else \"\"}\n        <p style=\"color:#666; font-style:italic; margin-bottom:15px;\">{pi$subheading}</p>\n        <p style=\"text-align:justify; line-height:1.5; margin-top:10px;font-size: 16px;\">{pi$description}</p>\n      </td>\n    </tr>\n  </table>\n</div>\n'))\n\n```\n\n------------------------------------------------------------------------\n\n```{r,echo=FALSE, message=FALSE, warning=T, results='asis'}\nlibrary(readxl)\nlibrary(tidyverse)\n\ncurrent <- read_xlsx(\"data/team.xlsx\") %>%\n  filter(status == \"current\") %>%\n  filter(!position == \"pi\")\n\nif (nrow(current) > 0) {\n\ncat('<center>[**Current members**]{style=\"font-size: 24px;\"}</center>')\n  \nfor (k in 1:nrow(current)) { \n  \ncurrent.member <- current[k,]\ncat(str_glue('\n<div style=\"margin-bottom: 20px; margin-top: 20px;\">\n  <table style=\"width: 100%; border-collapse: collapse; margin-bottom: 30px; background: transparent;\">\n    <tr>\n      <td style=\"width: 20%; vertical-align: top; padding-right: 20px;\">\n        <img src=\"{current.member$photo}\" alt=\"Profile Photo\" style=\"width: 100%; border-radius: 5%;\">\n      </td>\n      <td style=\"width: 80%; vertical-align: top;\">\n        <h3 style=\"margin-top: 0; margin-bottom: 5px;\">{current.member$name} <span class=\"fi fi-{current.member$nation}\" style=\"transform: scale(0.7); display: inline-block;\"></span></h3>\n        {if (!is.na(current.member$contact)) paste0(\\'<a href=\"mailto:\\', current.member$contact, \\'\" style=\"color:#444;margin-right:10px;\"><i class=\"bi bi-envelope-fill\"></i></a>\\') else \"\"}\n        {if (!is.na(current.member$linkedin)) paste0(\\'<a href=\"https://\\', current.member$linkedin, \\'\" style=\"color:#0077b5;margin-right:10px;\"><i class=\"bi bi-linkedin\"></i></a>\\') else \"\"}\n        {if (!is.na(current.member$bluesky)) paste0(\\'<a href=\"https://\\', current.member$bluesky, \\'\" style=\"color:#0085ff;margin-right:10px;\"><i class=\"bi bi-bluesky\"></i></a>\\') else \"\"}\n        <p style=\"color:#666; font-style:italic; margin-bottom:15px;\">{current.member$subheading}</p>\n        <p style=\"text-align:justify; line-height:1.5; margin-top:10px;font-size: 18px;\">{current.member$description}</p>\n      </td>\n    </tr>\n  </table>\n</div>\n'))\n\n\n}\n} else {invisible(NULL)}\n```\n\n------------------------------------------------------------------------\n\n```{r, echo=FALSE, message=FALSE, warning=FALSE, results='asis'}\nlibrary(readxl)\nlibrary(tidyverse)\n\nalumni <- read_xlsx(\"data/team.xlsx\") %>%\n  filter(status == \"alumni\") %>%\n  filter(!position == \"pi\") %>%\n  arrange(position)\n\nif (nrow(alumni) > 0) {\n  cat('<center>[**Alumni members**]{style=\"font-size: 24px;\"}</center>')\n  cat('<div style=\"display: grid; grid-template-columns: repeat(4, 1fr); gap: 20px; margin: 20px 0; align-items: start;\">')\n  \n  for (k in 1:nrow(alumni)) {\n    alumni.member <- alumni[k,]\n    \n    icons <- paste0(\n      if (!is.na(alumni.member$contact)) paste0('<a href=\"mailto:', alumni.member$contact, '\" style=\"color:#444;margin-right:10px;\"><i class=\"bi bi-envelope-fill\"></i></a>') else \"\",\n      if (!is.na(alumni.member$linkedin)) paste0('<a href=\"https://', alumni.member$linkedin, '\" style=\"color:#0077b5;margin-right:10px;\"><i class=\"bi bi-linkedin\"></i></a>') else \"\",\n      if (!is.na(alumni.member$bluesky)) paste0('<a href=\"https://', alumni.member$bluesky, '\" style=\"color:#0085ff;margin-right:10px;\"><i class=\"bi bi-bluesky\"></i></a>') else \"\"\n    )\n    \n    cat(str_glue('\n    <div style=\"text-align: center; padding: 10px;\">\n      <img src=\"{alumni.member$photo}\" alt=\"Profile Photo\"\n           style=\"width: 50%; border-radius: 10%; display: block; margin: 0 auto;\">\n      <h3 style=\"margin-top: 8px; margin-bottom: 5px; font-size: 18px;\">\n        {alumni.member$name}\n        <span class=\"fi fi-{alumni.member$nation}\" style=\"transform: scale(0.7); display: inline-block;\"></span>\n      </h3>\n      <div style=\"margin-top: 5px;\">{icons}</div>\n      <div style=\"margin-top: 5px;\">{alumni.member$subheading}</div>\n    </div>\n    '))\n  }\n  \n  cat('</div>')\n  \n} else { invisible(NULL) }\n```\n\n\n"},"formats":{"html":{"identifier":{"display-name":"HTML","target-format":"html","base-format":"html"},"execute":{"fig-width":7,"fig-height":5,"fig-format":"retina","fig-dpi":96,"df-print":"default","error":false,"eval":true,"cache":null,"freeze":false,"echo":true,"output":true,"warning":true,"include":true,"keep-md":false,"keep-ipynb":false,"ipynb":null,"enabled":null,"daemon":null,"daemon-restart":false,"debug":false,"ipynb-filters":[],"ipynb-shell-interactivity":null,"plotly-connected":true,"engine":"knitr"},"render":{"keep-tex":false,"keep-typ":false,"keep-source":false,"keep-hidden":false,"prefer-html":false,"output-divs":true,"output-ext":"html","fig-align":"default","fig-pos":null,"fig-env":null,"code-fold":"none","code-overflow":"scroll","code-link":false,"code-line-numbers":false,"code-tools":false,"tbl-colwidths":"auto","merge-includes":true,"inline-includes":false,"preserve-yaml":false,"latex-auto-mk":true,"latex-auto-install":true,"latex-clean":true,"latex-min-runs":1,"latex-max-runs":10,"latex-makeindex":"makeindex","latex-makeindex-opts":[],"latex-tlmgr-opts":[],"latex-input-paths":[],"latex-output-dir":null,"link-external-icon":false,"link-external-newwindow":false,"self-contained-math":false,"format-resources":[],"notebook-links":true},"pandoc":{"standalone":true,"wrap":"none","default-image-extension":"png","to":"html","toc":false,"css":["style.css"],"output-file":"team.html"},"language":{"toc-title-document":"Table of contents","toc-title-website":"On this page","related-formats-title":"Other Formats","related-notebooks-title":"Notebooks","source-notebooks-prefix":"Source","other-links-title":"Other Links","code-links-title":"Code Links","launch-dev-container-title":"Launch Dev Container","launch-binder-title":"Launch Binder","article-notebook-lab