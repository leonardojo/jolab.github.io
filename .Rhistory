cat(paste0("#### ", k, "\n"))
for(i in 1:nrow(pubs.year)) {
# Check correspondence logic
corr_label <- if(pubs.year$correspondingauthor[i] == "yes") " **(Corresponding Author)**" else ""
# Print the formatted line
cat(paste0("####### ", pubs.year$fullref[i], "\n"))
cat(paste0("- [", pubs.year$doi[i], "](https://doi.org/", pubs$doi[i], ")", corr_label, "\n\n"))
}
}
